# Default is local SQLite (zero infra). For Postgres, start docker-compose and set:
# EDA_DATABASE_URL=postgresql+psycopg2://eda:eda-dev-only@localhost:5432/eda
EDA_DATABASE_URL=sqlite:///./eda.db

# HMAC secret for session tokens. MUST be replaced outside local dev.
EDA_TOKEN_SECRET=dev-only-secret-change-me

# Default TTL (seconds) for brokered grants; policy obligations may shorten it.
EDA_GRANT_TTL=900

# --- Identity front ---------------------------------------------------------
# "dev": self-issued HMAC sessions (tests/local demos ONLY).
# "oidc": validate bearer tokens against your provider; the dev session
#         endpoint is disabled and seeded identities stop resolving.
EDA_AUTH_MODE=dev

# Required in oidc mode. Examples:
#   Okta:  issuer https://acme.okta.com/oauth2/default, prefix okta,
#          static tenant (single org): EDA_OIDC_STATIC_TENANT=acme
#   Entra: issuer https://login.microsoftonline.com/<tenant>/v2.0, prefix entra,
#          tenant claim: EDA_OIDC_TENANT_CLAIM=tid
#EDA_OIDC_ISSUER=
#EDA_OIDC_AUDIENCE=
#EDA_OIDC_JWKS_URL=
#EDA_OIDC_PROVIDER_PREFIX=okta
#EDA_OIDC_TENANT_CLAIM=tid
#EDA_OIDC_STATIC_TENANT=
#EDA_OIDC_GROUPS_CLAIM=groups
#EDA_OIDC_MFA_AMR=mfa,otp,hwk,swk
#EDA_OIDC_MFA_ACR=

# --- Relationship ingestion ---------------------------------------------------
#EDA_INGEST_MAX_BATCH=1000
# Sources that haven't synced within this window are stale: identities they
# asserted stop resolving until the collector syncs again (fail closed).
#EDA_SOURCE_MAX_AGE=604800
